# Copy to .env.local for local development

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only: required for public game play + secure writes (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: set to "true" to force demo data without database writes
NEXT_PUBLIC_LOCAL_ONLY_MODE=false

# Optional analytics filter baseline (ISO timestamp) — also manageable in Admin
# STATS_RESET_AT=2026-01-01T00:00:00.000Z
