# Copy to .env.local for local development

# Database (Vercel Postgres / Neon — pooled connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Single shared admin login (staff console / prize management)
# Use a long random password. ADMIN_SESSION_SECRET must be unguessable (32+ chars).
ADMIN_PASSWORD=change-me-to-a-long-random-string
ADMIN_SESSION_SECRET=use-openssl-rand-hex-32-or-similar-long-secret

# Optional: set to "true" to force demo catalog + non-persisted plays
NEXT_PUBLIC_LOCAL_ONLY_MODE=false

# Optional analytics filter baseline (ISO timestamp)
# STATS_RESET_AT=2026-01-01T00:00:00.000Z
